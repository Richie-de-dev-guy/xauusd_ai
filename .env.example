# ── Copy this file to .env and fill in your values ───────────────────────────
# Never commit .env to git.

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ── Dashboard credentials (single-user Phase 1) ───────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme

# ── CORS — allowed frontend origins ───────────────────────────────────────────
# For local dev: http://localhost:3000
# For production: https://your-dashboard-domain.com
CORS_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is used by default. Change to a PostgreSQL URL for production:
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname
DATABASE_URL=sqlite+aiosqlite:///./sentinel.db

# ── Telegram (Plan 1 signal broadcast) ───────────────────────────────────────
# Create a bot via @BotFather on Telegram, paste the token here.
# Leave blank to disable Telegram broadcasting.
TELEGRAM_BOT_TOKEN=
